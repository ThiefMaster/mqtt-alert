[mqtt.local]
hostname = '127.0.0.1'
# port = 1883
username = 'mqttalert'
password = ''
client_id = 'mqttalert'

[mqtt.ttn]
hostname = 'eu1.cloud.thethings.network'
# port = 1883
username = 'somebody@ttn'
password = ''
client_id = 'mqttalert'

[flood]
topics = ['shellies/flood-somewhere/sensor/flood']

[mailbox]
topics = ['v3/somewhere@ttn/devices/somedevice/up']

[freemdu]
topic = 'freemdu_home/588c8153e980/operating_mode/value'

[temperature]
'v3/sombody@ttn/devices/fridge-temperature/up' = 5
'v3/sombody@ttn/devices/freezer-temperature/up' = -18

[pushover]
user = '...'
token = '...'
